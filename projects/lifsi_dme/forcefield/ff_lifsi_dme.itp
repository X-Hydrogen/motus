 14  13  15   1       107.8       276.144  ; H-C-H
 14  13  16   1       107.8       276.144  ; H-C-H
 15  13  16   1       107.8       276.144  ; H-C-H

[ dihedrals ]
; ai  aj  ak  al  funct   phi0      k     mult
; C-O-C-H (improper-like, use proper)
  1   5   6   7   1       0.0       0.650  3  ; X-O-C-X
  1   5   6   8   1       0.0       0.650  3
  1   5   6   9   1       0.0       0.650  3
  5   6   9  12   1       0.0       1.300  3  ; O-C-C-O
  5   6   9  10   1       0.0       0.650  3
  5   6   9  11   1       0.0       0.650  3
  6   9  12  13   1       0.0       0.650  3  ; C-C-O-C
  9  12  13  14   1       0.0       0.650  3
  9  12  13  15   1       0.0       0.650  3
  9  12  13  16   1       0.0       0.650  3
 13  12   9   6   1       0.0       1.300  3
  ; O-C-C-O proper dihedral (important for DME)
  5   6   9  12   9       0.0       1.882  1  ; trans
  5   6   9  12   9       0.0      -0.879  2  ; gauche
  5   6   9  12   9       0.0       0.945  3  ; trans correction
  5   6   9  12   9       0.0       0.000  4

; ============================================================
; FSI- (bis(fluorosulfonyl)imide) - N(SO2F)2-
; ============================================================
[ moleculetype ]
; name       nrexcl
FSI          3

[ atoms ]
; id  type   resnr residu name atname cgnr charge   mass
  1  opls_040  1   FSI     N       1  -0.650   14.00670 ; N central
  2  opls_038  1   FSI     S1      2   1.200   32.06000 ; S
  3  opls_018  1   FSI     O1A     3  -0.600   15.99940 ; S=O
  4  opls_018  1   FSI     O1B     3  -0.600   15.99940 ; S=O
  5  opls_164  1   FSI     F1      4  -0.175   18.99840 ; S-F
  6  opls_038  1   FSI     S2      5   1.200   32.06000 ; S
  7  opls_018  1   FSI     O2A     6  -0.600   15.99940 ; S=O
  8  opls_018  1   FSI     O2B     6  -0.600   15.99940 ; S=O
  9  opls_164  1   FSI     F2      7  -0.175   18.99840 ; S-F

; Total charge: -0.650 + 2*(1.200) + 4*(-0.600) + 2*(-0.175) = -1.0
; Check: -0.650 + 2.400 - 2.400 - 0.350 = -1.000 ✓

[ bonds ]
; ai  aj  funct   r           k
  1   2   1       0.1570      251040.0  ; N-S
  1   6   1       0.1570      251040.0  ; N-S
