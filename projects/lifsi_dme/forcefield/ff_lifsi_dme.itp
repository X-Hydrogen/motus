; Force field for LiFSI/DME system
; Based on OPLS-AA with literature parameters for FSI-
;
; References:
;   Jorgensen et al., JACS 118, 11225 (1996) - OPLS-AA
;   Canongia Lopes & Pádua, JPCB 110, 19586 (2006) - ionic liquids
;   Borodin, JPCB 113, 11463 (2009) - LiFSI parameters
;   Shimizu et al., JPCB 119, 8961 (2015) - FSI- parameters

[ defaults ]
; nbfunc comb-rule gen-pairs fudgeLJ fudgeQQ
    1      3        yes      0.5     0.5

#include "oplsaa.ff/ffnonbonded.itp"
#include "oplsaa.ff/ffbonded.itp"

; ============================================================
; Custom atom types (not in standard OPLS-AA)
; We'll use existing OPLS types where possible
; ============================================================

; Li+ - use opls_406 (already defined)
; FSI- uses:
;   S: opls_035 (sulfide S) modified - actually use opls_038
;   O: opls_018 (carbonyl O) - for S=O
;   N: opls_040 (amine N) - for N-SO2
;   F: opls_164 (F in trifluoroethanol)
;
; DME uses:
;   CH3-O: opls_181
;   CH2-O: opls_182  
;   O: opls_180 (dialkyl ether)
;   H: opls_140 (alkane H)
;   H on C-O: opls_185

; ============================================================
; DME (1,2-dimethoxyethane) - CH3-O-CH2-CH2-O-CH3
; ============================================================
[ moleculetype ]
; name       nrexcl
DME          3

[ atoms ]
; id  type   resnr residu name atname cgnr charge   mass
  1  opls_181  1   DME    C1      1   0.110   15.03500 ; CH3-O
  2  opls_185  1   DME    H1A     1   0.030    1.00800 ; H on C-O
  3  opls_185  1   DME    H1B     1   0.030    1.00800 ; H on C-O
  4  opls_185  1   DME    H1C     1   0.030    1.00800 ; H on C-O
  5  opls_180  1   DME    O1      2  -0.400   15.99940 ; ether O
  6  opls_182  1   DME    C2      3   0.140   14.02700 ; CH2-O
  7  opls_185  1   DME    H2A     3   0.030    1.00800 ; H on C-O
  8  opls_185  1   DME    H2B     3   0.030    1.00800 ; H on C-O
  9  opls_182  1   DME    C3      4   0.140   14.02700 ; CH2-O
 10  opls_185  1   DME    H3A     4   0.030    1.00800 ; H on C-O
 11  opls_185  1   DME    H3B     4   0.030    1.00800 ; H on C-O
 12  opls_180  1   DME    O2      5  -0.400   15.99940 ; ether O
 13  opls_181  1   DME    C4      6   0.110   15.03500 ; CH3-O
 14  opls_185  1   DME    H4A     6   0.030    1.00800 ; H on C-O
 15  opls_185  1   DME    H4B     6   0.030    1.00800 ; H on C-O
 16  opls_185  1   DME    H4C     6   0.030    1.00800 ; H on C-O

[ bonds ]
; ai  aj  funct   r           k
  1   2   1       0.1090      284512.0  ; C-H
  1   3   1       0.1090      284512.0  ; C-H
  1   4   1       0.1090      284512.0  ; C-H
